# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. Never paste tokens into MCP client settings.json or
# any committed file.

# freee 人事労務 OAuth2 access token. Required.
# Issue from the freee Developers app console: https://app.secure.freee.co.jp/developers/applications
FREEE_ACCESS_TOKEN=

# Optional: default company_id used when a tool call omits it.
FREEE_COMPANY_ID=

# Optional: override base URL (defaults to https://api.freee.co.jp/hr/api/v1).
# FREEE_HR_BASE_URL=

# Optional: load environment variables from a different .env path.
# Set this in the MCP client config when keeping the .env outside the repo.
# FREEE_HR_ENV_FILE=
