# freee HR (人事労務) OAuth2 access token. Required.
# Obtain via the freee Developers app console: https://app.secure.freee.co.jp/developers/applications
FREEE_ACCESS_TOKEN=

# Optional: default company_id used when a tool call omits it.
FREEE_COMPANY_ID=

# Optional: override base URL (defaults to https://api.freee.co.jp/hr/api/v1).
# FREEE_HR_BASE_URL=
