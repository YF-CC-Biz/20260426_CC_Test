# Copy to `.env.token` and fill in. The file is git-ignored.
# `node scripts/exchange-token.mjs` will read it once, exchange the code
# for an access_token, write it to `.env`, and DELETE this file.

FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=
FREEE_AUTH_CODE=
# FREEE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
